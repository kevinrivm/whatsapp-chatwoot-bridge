# ═══════════════════════════════════════════════════════════════════════════════
# WhatsApp-Chatwoot Bridge — Credenciales
# Copiar este archivo como .env y rellenar todos los valores antes de abrir Claude.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Meta ────────────────────────────────────────────────────────────────────

# Token que tú inventas (cualquier cadena sin espacios).
# Lo usarás también al aplicar el override en Meta.
META_VERIFY_TOKEN=

# System User Token permanente (NO el token de usuario de 60 días).
# Crearlo en: Meta Business Manager → Configuración → Usuarios del sistema → Generar token
META_ACCESS_TOKEN=

# Versión de la API de Meta. No cambiar salvo aviso de deprecación.
META_API_VERSION=v21.0

# ─── Chatwoot ────────────────────────────────────────────────────────────────

# URL base de tu Chatwoot, sin slash final.
# Ejemplo: https://chat.tudominio.com
CHATWOOT_BASE_URL=

# Access Token de Chatwoot.
# Dónde encontrarlo: Chatwoot → Avatar abajo izq → Profile Settings → Access Token
CHATWOOT_API_TOKEN=

# ID de la cuenta en Chatwoot.
# Dónde encontrarlo: número en la URL → /app/accounts/{ID}/
CHATWOOT_ACCOUNT_ID=1

# HMAC Secret del webhook de Chatwoot.
# Dejar vacío ahora — Claude lo configurará después de crear el webhook en Chatwoot.
CHATWOOT_WEBHOOK_SECRET=

# ─── Routing table ───────────────────────────────────────────────────────────
# Una entrada por número de WhatsApp. JSON en una sola línea (sin saltos de línea).
#
# Campos por entrada:
#   phone_number_id → Meta Developers → WhatsApp → API Setup
#   chatwoot_phone  → dígitos del inbox en Chatwoot, SIN + y SIN dígito troncal
#                     México: 524XXXXXXXXX (12 dígitos), NO 5214XXXXXXXXX (13 dígitos)
#   inbox_id        → número en la URL del inbox: Settings → Inboxes → click inbox → URL
#
# Un número:
PHONE_ROUTING=[{"phone_number_id":"","chatwoot_phone":"","inbox_id":1}]
#
# Dos números (ejemplo):
# PHONE_ROUTING=[{"phone_number_id":"ID1","chatwoot_phone":"52XXXXXXXXXX","inbox_id":1},{"phone_number_id":"ID2","chatwoot_phone":"52YYYYYYYYYY","inbox_id":2}]

# ─── Configuración del bridge ────────────────────────────────────────────────

# Subdominio donde quedará el bridge, SIN https://.
# Ejemplo: wa-bridge.tudominio.com
# El DNS de este subdominio debe apuntar a la IP de tu VPS antes del deploy.
BRIDGE_DOMAIN=

# ─── Coolify (para el MCP — no se envía al bridge) ───────────────────────────

# URL de tu instancia de Coolify, CON slash final.
# Ejemplo: https://coolify.tudominio.com/
# También va en .mcp.json — mantener sincronizados.
COOLIFY_BASE_URL=

# API Token de Coolify.
# Dónde encontrarlo: Coolify → Profile (arriba derecha) → Keys & Tokens → API tokens → + Create
# También va en .mcp.json — mantener sincronizados.
COOLIFY_API_TOKEN=
