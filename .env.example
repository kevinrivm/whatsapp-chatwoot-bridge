# ─── Meta ────────────────────────────────────────────────────────────────────
# Token de verificación inventado por ti (mismo valor que usas en override_callback_uri)
META_VERIFY_TOKEN=your_verify_token

# System User Token permanente (NO el token de usuario de 60 días)
META_ACCESS_TOKEN=

# Versión de la API de Meta (no cambiar salvo aviso de deprecación)
META_API_VERSION=v21.0

# ─── Chatwoot ────────────────────────────────────────────────────────────────
CHATWOOT_BASE_URL=https://chatwoot.tudominio.com
CHATWOOT_API_TOKEN=          # Avatar → Profile Settings → Access Token
CHATWOOT_ACCOUNT_ID=1        # Número en la URL: /app/accounts/{ID}/

# HMAC secret del webhook de Chatwoot (Settings → Integrations → Webhooks)
# Dejar vacío hasta crear el webhook, luego redeploy.
CHATWOOT_WEBHOOK_SECRET=

# ─── Routing table ───────────────────────────────────────────────────────────
# Una entrada por número de WhatsApp. JSON en una sola línea.
#
# Campos:
#   phone_number_id  → Meta Phone Number ID (Meta Developers → WhatsApp → API Setup)
#   chatwoot_phone   → dígitos del número tal como está registrado en el inbox de Chatwoot
#                      (sin +, sin dígito troncal para México: 524623749518 NO 5214623749518)
#   inbox_id         → ID del inbox en Chatwoot (Settings → Inboxes → URL del inbox)
#
# Ejemplo un número:
# PHONE_ROUTING=[{"phone_number_id":"761549910376296","chatwoot_phone":"524623749518","inbox_id":1}]
#
# Ejemplo dos números:
# PHONE_ROUTING=[{"phone_number_id":"761549910376296","chatwoot_phone":"524623749518","inbox_id":1},{"phone_number_id":"987654321098765","chatwoot_phone":"521XXXXXXXXXX","inbox_id":2}]
#
PHONE_ROUTING=[{"phone_number_id":"YOUR_PHONE_NUMBER_ID","chatwoot_phone":"YOUR_INBOX_PHONE_DIGITS","inbox_id":1}]
